# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:password123@localhost:5432/medusa-store
DATABASE_URL=postgresql://postgres:password@localhost:5432/medusa-store

# ============================================
# REDIS CONFIGURATION (Optional but Recommended)
# ============================================
# Redis is used for job queuing and caching
# If you don't have Redis, you can skip this for now
REDIS_URL=redis://localhost:6379

# ============================================
# SECURITY SECRETS
# ============================================
# Generate random strings for these (use: https://generate-secret.vercel.app/32)
# These should be long, random, and unique
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
COOKIE_SECRET=change-me-to-another-long-random-string-min-32-chars

# ============================================
# CORS CONFIGURATION
# ============================================
# These URLs tell Medusa which frontends can access the API
# For local development, use these exact values:
ADMIN_CORS=http://localhost:9001
STORE_CORS=http://localhost:9002,http://localhost:5173
AUTH_CORS=http://localhost:9001,http://localhost:9002,http://localhost:5173

# ============================================
# FILE STORAGE (S3 - Optional)
# ============================================
# If you want to upload images, you'll need S3 or S3-compatible storage
# You can leave these empty for now and add them later
# For AWS S3:
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FILE_URL=

# For Cloudflare R2 (alternative to S3):
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_FILE_URL=
R2_PREFIX=

# ============================================
# PAYMENT PROVIDERS (Optional)
# ============================================
# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# BACKEND URL (for emails and links)
# ============================================
MEDUSA_BACKEND_URL=http://localhost:9001
