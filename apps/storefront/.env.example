# ============================================
# BACKEND CONNECTION
# ============================================
# URL where your Medusa backend is running
# For local development, this should be:
VITE_MEDUSA_BACKEND_URL=http://localhost:9001

# ============================================
# PUBLISHABLE API KEY
# ============================================
# You'll get this key after starting your backend
# Run this command to get it: npx medusa exec ./src/scripts/get-publishable-key.ts
# Or login to admin dashboard and copy it from Settings > Publishable API Keys
VITE_MEDUSA_PUBLISHABLE_KEY=

# ============================================
# STRIPE PUBLISHABLE KEY (Optional)
# ============================================
# If you're using Stripe for payments
# Get this from: https://dashboard.stripe.com/apikeys
# This is the PUBLIC key (starts with pk_)
VITE_STRIPE_PUBLISHABLE_KEY=

# ============================================
# DEVELOPMENT SERVER CONFIGURATION
# ============================================
# Port for the storefront development server
VITE_PORT=9002

# Hot Module Replacement port (for live reloading)
VITE_HMR_PORT=24677

# Deployment target (ignore this for local development)
VITE_DEPLOYMENT_TARGET=local
